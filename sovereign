#!/bin/bash

# sovereign - Autonomous Server Management CLI (GitHub backed)

# Configuration
REPO_USER="${REPO_USER:-crapougnax}"
REPO_NAME="${REPO_NAME:-sovereign}"
REPO_BRANCH="${REPO_BRANCH:-main}"
GITHUB_RAW="https://raw.githubusercontent.com/$REPO_USER/$REPO_NAME/$REPO_BRANCH"
GITHUB_API="https://api.github.com/repos/$REPO_USER/$REPO_NAME"

WORK_DIR="$HOME/.sovereign"
PODMAN_DIR="$WORK_DIR/podman"
ENV_FILE="$WORK_DIR/.env"
PLATFORM="podman"

mkdir -p "$PODMAN_DIR/core" "$PODMAN_DIR/recipes"

# --- Utils ---

function log() { echo -e "\e[32m[sovereign]\e[0m $1"; }
function error() { echo -e "\e[31m[error]\e[0m $1"; exit 1; }

function check_env() {
    if [ ! -f "$ENV_FILE" ]; then
        error "Configuration file (.env) not found. Please run 'sovereign setup' first."
    fi
}

function check_port_conflicts() {
    local ports=("$@")
    for port in "${ports[@]}"; do
        if ss -tulpn 2>/dev/null | grep -q ":$port "; then
            return 0 # Conflict found
        fi
    done
    return 1 # No conflict
}

function get_app_subdomain() {
    local app_name=$1
    local env_var_name="$(echo ${app_name} | tr '[:lower:]' '[:upper:]' | tr '-' '_')_SUBDOMAIN"
    
    # Check if already in .env
    local existing=$(grep "^$env_var_name=" "$ENV_FILE" | cut -d'=' -f2)
    if [[ -n "$existing" ]]; then
        echo "$existing"
        return
    fi

    # Prompt user
    read -p "Enter subdomain for $app_name [default: $app_name]: " subdomain
    subdomain=${subdomain:-$app_name}
    
    # Check for duplicates in current user's containers
    if podman ps --filter "label=traefik.http.routers.${app_name}.rule" --format "{{.Labels}}" | grep -q "Host(\`$subdomain."; then
        log "\e[33mWarning: Subdomain '$subdomain' seems already used by another container.\e[0m"
        read -p "Continue anyway? (y/N): " cont
        [[ "$cont" != "y" ]] && exit 1
    fi

    echo "$env_var_name=$subdomain" >> "$ENV_FILE"
    echo "$subdomain"
}

function fetch_remote_recipe() {
    local pkg=$1 # e.g., core/traefik or recipes/immich
    local target_dir="$WORK_DIR/$PLATFORM/$pkg"
    
    log "Fetching $pkg from GitHub..."
    mkdir -p "$target_dir"
    
    curl -s -f "$GITHUB_RAW/$PLATFORM/$pkg/compose.yaml" -o "$target_dir/compose.yaml" || \
    curl -s -f "$GITHUB_RAW/$PLATFORM/$pkg/compose.yml" -o "$target_dir/compose.yaml" || \
    error "Failed to fetch recipe $pkg from $GITHUB_RAW"
    
    # Fetch package.json if it exists
    curl -s -f "$GITHUB_RAW/$PLATFORM/$pkg/package.json" -o "$target_dir/package.json" 2>/dev/null

    # Also fetch dynamic config if it's traefik
    if [[ "$pkg" == "core/traefik" ]]; then
        log "Fetching Traefik dynamic configuration..."
        mkdir -p "$target_dir/traefik-dynamic"
        curl -s -f "$GITHUB_RAW/$PLATFORM/$pkg/traefik-dynamic/dashboard.yaml" -o "$target_dir/traefik-dynamic/dashboard.yaml"
    fi
}

function check_required_config() {
    local pkg_dir=$1
    if [ -f "$pkg_dir/package.json" ]; then
        local required=$(jq -r '.requiredEnv[]?' "$pkg_dir/package.json")
        for var in $required; do
            if ! grep -q "^$var=" "$ENV_FILE"; then
                log "Missing required configuration: $var"
                read -p "Enter value for $var: " value
                echo "$var=$value" >> "$ENV_FILE"
                log "Added $var to $ENV_FILE"
            fi
        done
    fi
}

# --- Commands ---

function do_setup() {
    log "Starting interactive setup..."
    
    if [ -f "$ENV_FILE" ]; then
        read -p "An .env file already exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" != "y" ]] && exit 0
    fi

    # Check for Traefik conflict early
    if check_port_conflicts 80 443; then
        log "\e[33mWarning: Ports 80 or 443 are already in use on this host.\e[0m"
        log "This usually means a Traefik or another reverse proxy is already running."
        log "You might not need to install 'core/traefik' for this user."
    fi

    if [ ! -f "$WORK_DIR/.env.dist" ]; then
        curl -s -f "$GITHUB_RAW/.env.dist" -o "$WORK_DIR/.env.dist" || error "Could not fetch .env.dist"
    fi
    
    cp "$WORK_DIR/.env.dist" "$ENV_FILE"

    read -p "Enter your domain name (e.g., apps.example.com): " domain
    sed -i "s|DOMAIN_NAME=.*|DOMAIN_NAME=$domain|g" "$ENV_FILE"

    read -p "Enter your email for SSL (Let's Encrypt): " email
    sed -i "s|SSL_EMAIL=.*|SSL_EMAIL=$email|g" "$ENV_FILE"

    log "Setup complete! Please edit $ENV_FILE for sensitive tokens."
}

function do_install() {
    check_env
    local pkg=$1
    [[ -z "$pkg" ]] && error "Usage: sovereign install <package> (e.g., traefik, immich)"

    local is_core=false
    if [[ "$pkg" == "core/"* ]] || [[ "$pkg" == "traefik" ]] || [[ "$pkg" == "smtp" ]]; then
        is_core=true
        [[ "$pkg" == "traefik" ]] && pkg="core/traefik"
        [[ "$pkg" == "smtp" ]] && pkg="core/smtp"
    else
        [[ "$pkg" != "recipes/"* ]] && pkg="recipes/$pkg"
    fi

    # Special check for Traefik
    if [[ "$pkg" == "core/traefik" ]]; then
        if check_port_conflicts 80 443; then
            log "\e[33mConflict: Ports 80/443 are already occupied.\e[0m"
            read -p "Are you sure you want to attempt Traefik installation? (y/N): " confirm_traefik
            [[ "$confirm_traefik" != "y" ]] && exit 0
        fi
    fi

    # Confirmation
    read -p "Are you sure you want to install/update $pkg? (y/N): " confirm
    [[ "$confirm" != "y" ]] && exit 0

    # Fetch
    fetch_remote_recipe "$pkg"
    local target_dir="$WORK_DIR/$PLATFORM/$pkg"

    # For non-core recipes, handle custom subdomain
    if [[ "$is_core" == "false" ]]; then
        local app_name=$(basename "$pkg")
        get_app_subdomain "$app_name" > /dev/null
    fi

    # Check for missing config
    check_required_config "$target_dir"

    # Install
    log "Deploying $pkg..."
    cd "$target_dir" && podman compose --env-file "$ENV_FILE" up -d
}

function do_uninstall() {
    check_env
    local pkg=$1
    [[ -z "$pkg" ]] && error "Usage: sovereign uninstall <package>"

    if [[ "$pkg" != *"/"* ]]; then
        pkg="recipes/$pkg"
    fi

    local target_dir="$WORK_DIR/$PLATFORM/$pkg"
    if [ ! -d "$target_dir" ]; then
        error "Package $pkg is not installed locally."
    fi

    read -p "Are you sure you want to UNINSTALL $pkg? This will stop services. (y/N): " confirm
    [[ "$confirm" != "y" ]] && exit 0

    log "Uninstalling $pkg..."
    local down_args=""
    
    read -p "Remove persistent volumes associated with $pkg? (y/N): " rm_volumes
    [[ "$rm_volumes" == "y" ]] && down_args="$down_args --volumes"
    
    # Podman compose down usually removes networks by default, but we can be explicit or just run the command
    cd "$target_dir" && podman compose --env-file "$ENV_FILE" down $down_args
    
    read -p "Delete local recipe files for $pkg? (y/N): " cleanup
    if [[ "$cleanup" == "y" ]]; then
        rm -rf "$target_dir"
        log "Local files for $pkg removed."
    fi
    
    log "$pkg has been uninstalled."
}

function do_list() {
    log "Fetching available recipes from GitHub..."
    if ! command -v jq &> /dev/null; then
        error "Listing recipes requires 'jq'. Please install it (sudo apt install jq)."
    fi

    local recipes_json
    recipes_json=$(curl -s -f "$GITHUB_API/contents/$PLATFORM/recipes?ref=$REPO_BRANCH")
    
    if [[ $? -ne 0 ]]; then
        error "Failed to reach GitHub API. Make sure the repository is public and REPO_USER is correct."
    fi

    echo ""
    printf "\e[1m%-20s %s\e[0m\n" "RECIPE" "DESCRIPTION"
    echo "------------------------------------------------------------"

    echo "$recipes_json" | jq -r '.[] | select(.type == "dir") | .name' | while read -r name; do
        local description
        description=$(curl -s -f "$GITHUB_RAW/$PLATFORM/recipes/$name/package.json" | jq -r '.description // empty')
        if [[ -z "$description" ]]; then
            description="(No description available)"
        fi
        printf "%-20s %s\n" "$name" "$description"
    done
    echo ""
}

function do_stats() {
    log "Server Statistics:"
    podman ps --format "table {{.Names}}\t{{.Status}}\t{{.CPUPerc}}\t{{.MemUsage}}"
}

function do_upgrade() {
    log "Upgrading Sovereign CLI from GitHub ($REPO_USER/$REPO_NAME)..."
    local tmp_file=$(mktemp)
    
    if curl -s -f "$GITHUB_RAW/sovereign" -o "$tmp_file"; then
        local current_exe=$(readlink -f "$0")
        chmod 755 "$tmp_file"
        
        if cp "$tmp_file" "$current_exe" 2>/dev/null; then
            rm -f "$tmp_file"
            log "Sovereign has been upgraded successfully!"
            exit 0
        else
            log "Permission denied. Attempting with sudo..."
            if sudo cp "$tmp_file" "$current_exe"; then
                sudo chmod 755 "$current_exe"
                rm -f "$tmp_file"
                log "Sovereign has been upgraded successfully (with sudo)!"
                exit 0
            else
                rm -f "$tmp_file"
                error "Failed to replace the executable even with sudo."
            fi
        fi
    else
        rm -f "$tmp_file"
        error "Failed to download the latest version from $GITHUB_RAW/sovereign"
    fi
}

function usage() {
    echo "Sovereign CLI - GitHub Edition"
    echo ""
    echo "Usage: sovereign [command] [args]"
    echo ""
    echo "Commands:"
    echo "  setup            Interactive setup"
    echo "  list             List available recipes from GitHub"
    echo "  install <pkg>    Install a recipe (e.g., immich, traefik)"
    echo "  uninstall <pkg>  Remove a recipe"
    echo "  upgrade          Update Sovereign CLI to the latest version"
    echo "  stats            System monitoring"
    echo "  ps               List active services"
    echo "  down <pkg>       Stop a service (keep config)"
    echo "  logs <pkg>       View logs"
    echo ""
}

# --- Router ---

case $1 in
    setup)       do_setup ;;
    list)        do_list ;;
    upgrade)     do_upgrade ;;
    install|up)  do_install "$2" ;;
    uninstall)   do_uninstall "$2" ;;
    stats)       do_stats ;;
    ps)          podman ps --filter "label=com.docker.compose.project" ;;
    down)
        check_env
        pkg=$2
        [[ "$pkg" != *"/"* ]] && pkg="recipes/$pkg"
        cd "$WORK_DIR/$PLATFORM/$pkg" && podman compose --env-file "$ENV_FILE" down
        ;;
    logs)
        check_env
        pkg=$2
        [[ "$pkg" != *"/"* ]] && pkg="recipes/$pkg"
        cd "$WORK_DIR/$PLATFORM/$pkg" && podman compose --env-file "$ENV_FILE" logs -f
        ;;
    *)
        usage
        ;;
esac
