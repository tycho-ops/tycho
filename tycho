#!/bin/bash

# tycho - Autonomous Server Management CLI (GitHub backed)

# Configuration
REPO_USER="${REPO_USER:-crapougnax}"
REPO_NAME="${REPO_NAME:-tycho}"
REPO_BRANCH="${REPO_BRANCH:-main}"
GITHUB_RAW="https://raw.githubusercontent.com/$REPO_USER/$REPO_NAME/$REPO_BRANCH"
GITHUB_API="https://api.github.com/repos/$REPO_USER/$REPO_NAME"

# Determine work directory and socket based on user (System vs User mode)
if [[ $EUID -eq 0 ]]; then
    WORK_DIR="/etc/tycho"
    ENV_FILE="/etc/tycho/.env"
    export PODMAN_SOCK="/run/podman/podman.sock"
    DEFAULT_STORAGE="/data/system"
else
    WORK_DIR="$HOME/.tycho"
    ENV_FILE="$WORK_DIR/.env"
    export PODMAN_SOCK="/run/user/$UID/podman/podman.sock"
    DEFAULT_STORAGE="/data/users/$USER"
fi

export TYCHO_WORK_DIR="$WORK_DIR"
export TYCHO_ENV_FILE="$ENV_FILE"

PODMAN_DIR="$WORK_DIR/podman"
PLATFORM="podman"

mkdir -p "$PODMAN_DIR/core" "$PODMAN_DIR/recipes"

# --- Utils ---

function log() { echo -e "\e[32m[tycho]\e[0m $1"; }
function error() { echo -e "\e[31m[error]\e[0m $1"; exit 1; }

function check_env() {
    if [[ ! -f "$ENV_FILE" ]]; then
        error "Configuration file (.env) not found. Please run 'tycho setup' first."
    fi
}

function resolve_compose_bin() {
    if command -v podman-compose &>/dev/null; then
        command -v podman-compose
    elif command -v docker-compose &>/dev/null; then
        command -v docker-compose
    else
        # Fallback to absolute podman compose wrapper
        local podman_path
        podman_path=$(command -v podman 2>/dev/null || echo "/usr/bin/podman")
        echo "$podman_path compose --"
    fi
}

function run_podman_compose() {
    local dir="$1"
    shift
    
    if [[ -d "$dir" ]]; then
        ln -sf "$ENV_FILE" "$dir/.env" 2>/dev/null || true
    fi
    
    (
        cd "$dir" || exit 1
        if [[ -f "$ENV_FILE" ]]; then
            set -a
            source "$ENV_FILE"
            set +a
        fi
        local compose_bin
        compose_bin=$(resolve_compose_bin)
        $compose_bin "$@"
    )
    return $?
}


function check_port_conflicts() {
    local ports=("$@")
    for port in "${ports[@]}"; do
        if ss -tulpn 2>/dev/null | grep -q ":$port "; then
            return 0 # Conflict found
        fi
    done
    return 1 # No conflict
}

function get_app_subdomain() {
    local app_name=$1
    local env_var_name="$(echo ${app_name} | tr '[:lower:]' '[:upper:]' | tr '-' '_')_SUBDOMAIN"
    
    # Check if already in .env
    local existing=$(grep "^$env_var_name=" "$ENV_FILE" | cut -d'=' -f2)
    if [[ -n "$existing" ]]; then
        echo "$existing"
        return
    fi

    # Prompt user
    read -p "Enter subdomain for $app_name [default: $app_name]: " subdomain
    subdomain=${subdomain:-$app_name}
    
    # Check for duplicates
    if podman ps --filter "label=traefik.http.routers.${app_name}.rule" --format "{{.Labels}}" | grep -q "Host(\`$subdomain."; then
        log "\e[33mWarning: Subdomain '$subdomain' seems already used by another container.\e[0m"
        read -p "Continue anyway? (y/N): " cont
        [[ "$cont" != "y" ]] && exit 1
    fi

    echo "$env_var_name=$subdomain" >> "$ENV_FILE"
    echo "$subdomain"
}

function resolve_local_pkg_dir() {
    local pkg=$1
    [[ -z "$pkg" ]] && return 1

    if [[ "$pkg" == "core/"* ]]; then
        echo "$WORK_DIR/$PLATFORM/$pkg"
        return 0
    fi

    if [[ "$pkg" == "recipes/"* ]]; then
        echo "$WORK_DIR/$PLATFORM/$pkg"
        return 0
    fi

    if [[ -d "$WORK_DIR/$PLATFORM/recipes/$pkg" ]]; then
        echo "$WORK_DIR/$PLATFORM/recipes/$pkg"
        return 0
    fi

    if [[ "$pkg" == "traefik" ]] || [[ "$pkg" == "smtp" ]]; then
        echo "$WORK_DIR/$PLATFORM/core/$pkg"
        return 0
    fi

    if [[ -f "$WORK_DIR/repositories.json" ]]; then
        local repos=$(jq -r '.[].name' "$WORK_DIR/repositories.json" 2>/dev/null)
        for r in $repos; do
            if [[ -d "$WORK_DIR/$PLATFORM/recipes/$r/$pkg" ]]; then
                echo "$WORK_DIR/$PLATFORM/recipes/$r/$pkg"
                return 0
            fi
        done
    fi

    echo "$WORK_DIR/$PLATFORM/recipes/$pkg"
    return 0
}

function find_recipe_repo() {
    local search_pkg=$1
    local r_name=""
    local recipe_name=""

    if [[ "$search_pkg" == *"/"* ]]; then
        r_name="${search_pkg%%/*}"
        recipe_name="${search_pkg#*/}"
    else
        recipe_name="$search_pkg"
    fi

    if [[ -n "$r_name" ]]; then
        if [[ "$r_name" == "official" ]]; then
            if curl -s -f -I "https://raw.githubusercontent.com/$REPO_USER/$REPO_NAME/$REPO_BRANCH/.tycho/recipes/$PLATFORM/$recipe_name/package.json" &>/dev/null || \
               curl -s -f -I "https://raw.githubusercontent.com/$REPO_USER/$REPO_NAME/$REPO_BRANCH/.tycho/recipes/$PLATFORM/$recipe_name/compose.yaml" &>/dev/null; then
                echo "official;$REPO_USER;$REPO_NAME;$REPO_BRANCH;$recipe_name"
                return 0
            fi
        elif [[ -f "$WORK_DIR/repositories.json" ]]; then
            local repo_json=$(jq -c ".[] | select(.name == \"$r_name\")" "$WORK_DIR/repositories.json" 2>/dev/null)
            if [[ -n "$repo_json" ]]; then
                local r_owner=$(echo "$repo_json" | jq -r '.owner')
                local r_repo=$(echo "$repo_json" | jq -r '.repo')
                local r_branch=$(echo "$repo_json" | jq -r '.branch')
                if curl -s -f -I "https://raw.githubusercontent.com/$r_owner/$r_repo/$r_branch/.tycho/recipes/$PLATFORM/$recipe_name/package.json" &>/dev/null || \
                   curl -s -f -I "https://raw.githubusercontent.com/$r_owner/$r_repo/$r_branch/.tycho/recipes/$PLATFORM/$recipe_name/compose.yaml" &>/dev/null; then
                    echo "$r_name;$r_owner;$r_repo;$r_branch;$recipe_name"
                    return 0
                fi
            fi
        fi
        return 1
    fi

    if curl -s -f -I "https://raw.githubusercontent.com/$REPO_USER/$REPO_NAME/$REPO_BRANCH/.tycho/recipes/$PLATFORM/$recipe_name/package.json" &>/dev/null || \
       curl -s -f -I "https://raw.githubusercontent.com/$REPO_USER/$REPO_NAME/$REPO_BRANCH/.tycho/recipes/$PLATFORM/$recipe_name/compose.yaml" &>/dev/null; then
        echo "official;$REPO_USER;$REPO_NAME;$REPO_BRANCH;$recipe_name"
        return 0
    fi

    if [[ -f "$WORK_DIR/repositories.json" ]]; then
        local repos=$(jq -c '.[]' "$WORK_DIR/repositories.json" 2>/dev/null)
        if [[ -n "$repos" ]]; then
            while read -r repo_json; do
                local r_name=$(echo "$repo_json" | jq -r '.name')
                local r_owner=$(echo "$repo_json" | jq -r '.owner')
                local r_repo=$(echo "$repo_json" | jq -r '.repo')
                local r_branch=$(echo "$repo_json" | jq -r '.branch')
                if curl -s -f -I "https://raw.githubusercontent.com/$r_owner/$r_repo/$r_branch/.tycho/recipes/$PLATFORM/$recipe_name/package.json" &>/dev/null || \
                   curl -s -f -I "https://raw.githubusercontent.com/$r_owner/$r_repo/$r_branch/.tycho/recipes/$PLATFORM/$recipe_name/compose.yaml" &>/dev/null; then
                    echo "$r_name;$r_owner;$r_repo;$r_branch;$recipe_name"
                    return 0
                fi
            done <<< "$repos"
        fi
    fi

    return 1
}

function fetch_remote_recipe() {
    local pkg=$1
    local r_name=$2
    local r_owner=$3
    local r_repo=$4
    local r_branch=$5
    local recipe_name=$6
    local is_core=$7

    local target_dir="$WORK_DIR/$PLATFORM/$pkg"
    local raw_url="https://raw.githubusercontent.com/$r_owner/$r_repo/$r_branch"

    if [[ "$is_core" == "true" ]]; then
        log "Fetching core service $recipe_name from official repository..."
        mkdir -p "$target_dir"
        curl -s -f "$raw_url/.tycho/core/$PLATFORM/$recipe_name/compose.yaml" -o "$target_dir/compose.yaml" || \
        curl -s -f "$raw_url/.tycho/core/$PLATFORM/$recipe_name/compose.yml" -o "$target_dir/compose.yaml" || \
        error "Failed to fetch core service $recipe_name from $raw_url"

        if [[ "$recipe_name" == "traefik" ]]; then
            log "Fetching Traefik dynamic configuration..."
            mkdir -p "$target_dir/traefik-dynamic"
            curl -s -f "$raw_url/.tycho/core/$PLATFORM/$recipe_name/traefik-dynamic/dashboard.yaml" -o "$target_dir/traefik-dynamic/dashboard.yaml"
        fi
    else
        log "Fetching recipe $recipe_name from repository '$r_name' ($r_owner/$r_repo)..."
        mkdir -p "$target_dir"
        curl -s -f "$raw_url/.tycho/recipes/$PLATFORM/$recipe_name/compose.yaml" -o "$target_dir/compose.yaml" || \
        curl -s -f "$raw_url/.tycho/recipes/$PLATFORM/$recipe_name/compose.yml" -o "$target_dir/compose.yaml" || \
        error "Failed to fetch recipe $recipe_name from $raw_url"

        curl -s -f "$raw_url/.tycho/recipes/$PLATFORM/$recipe_name/package.json" -o "$target_dir/package.json" 2>/dev/null
    fi
}

function check_required_config() {
    local pkg_dir=$1
    local app_name=$(basename "$pkg_dir")
    local base_storage=$(grep "^BASE_STORAGE_PATH=" "$ENV_FILE" | cut -d'=' -f2)

    if [[ -f "$pkg_dir/package.json" ]]; then
        local required=$(jq -r '.requiredEnv[]?' "$pkg_dir/package.json")
        for var in $required; do
            if ! grep -q "^$var=" "$ENV_FILE"; then
                local default_val=""
                # Suggest path if variable looks like a location
                if [[ "$var" == *"LOCATION"* ]] || [[ "$var" == *"PATH"* ]] || [[ "$var" == *"DIR"* ]]; then
                    local sub_path=$(echo "$var" | tr '[:upper:]' '[:lower:]' | sed 's/_location//;s/_path//;s/_dir//')
                    default_val="$base_storage/$app_name/$sub_path"
                fi

                log "Missing required configuration: $var"
                read -p "Enter value for $var [default: $default_val]: " value
                value=${value:-$default_val}
                
                # Create directory if it looks like a path
                if [[ "$value" == /* ]]; then
                    mkdir -p "$value"
                    log "Created directory: $value"
                fi

                echo "$var=$value" >> "$ENV_FILE"
                log "Added $var to $ENV_FILE"
            fi
        done
    fi
}

# --- Commands ---

function do_setup() {
    log "Starting interactive setup (Mode: $([[ $EUID -eq 0 ]] && echo 'SYSTEM' || echo 'USER'))..."
    
    if [[ -f "$ENV_FILE" ]]; then
        read -p "An .env file already exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" != "y" ]] && exit 0
    fi

    if [[ $EUID -ne 0 ]] && check_port_conflicts 80 443; then
        log "\e[33mWarning: Ports 80 or 443 are already in use by SYSTEM.\e[0m"
        log "You should probably NOT install Traefik in USER mode."
    fi

    if [[ ! -f "$WORK_DIR/.env.dist" ]]; then
        curl -s -f "$GITHUB_RAW/.env.dist" -o "$WORK_DIR/.env.dist" || error "Could not fetch .env.dist"
    fi
    
    cp "$WORK_DIR/.env.dist" "$ENV_FILE"

    read -p "Enter your domain name (e.g., apps.example.com): " domain
    sed -i "s|DOMAIN_NAME=.*|DOMAIN_NAME=$domain|g" "$ENV_FILE"

    read -p "Enter your email for SSL (Let's Encrypt): " email
    sed -i "s|SSL_EMAIL=.*|SSL_EMAIL=$email|g" "$ENV_FILE"

    read -p "Enter base storage path for your apps [default: $DEFAULT_STORAGE]: " base_storage
    base_storage=${base_storage:-$DEFAULT_STORAGE}
    
    # Security/Isolation check: if user mode and path is outside home, ensure it has /user suffix
    if [[ $EUID -ne 0 ]] && [[ "$base_storage" == /data* ]] && [[ "$base_storage" != */$USER ]]; then
        log "\e[33mWarning: You chose a shared path ($base_storage) without your username suffix.\e[0m"
        read -p "Append /$USER to ensure isolation? (Y/n): " append_user
        if [[ "$append_user" != "n" ]]; then
            base_storage="$base_storage/$USER"
            log "Path updated to: $base_storage"
        fi
    fi

    mkdir -p "$base_storage"
    sed -i "s|BASE_STORAGE_PATH=.*|BASE_STORAGE_PATH=$base_storage|g" "$ENV_FILE"

    log "Setup complete! Configuration stored in $ENV_FILE"
}

function do_install() {
    check_env
    local pkg=$1
    [[ -z "$pkg" ]] && error "Usage: tycho install [repo/]package"

    local is_core=false
    local app_name=""
    local r_name="official"
    local r_owner="$REPO_USER"
    local r_repo="$REPO_NAME"
    local r_branch="$REPO_BRANCH"

    if [[ "$pkg" == "core/"* ]] || [[ "$pkg" == "traefik" ]] || [[ "$pkg" == "smtp" ]]; then
        is_core=true
        [[ "$pkg" == "traefik" ]] && pkg="core/traefik"
        [[ "$pkg" == "smtp" ]] && pkg="core/smtp"
        app_name=$(basename "$pkg")
    else
        local search_pkg="${pkg#recipes/}"
        local match_info=$(find_recipe_repo "$search_pkg")
        if [[ $? -ne 0 ]] || [[ -z "$match_info" ]]; then
            error "Recipe '$search_pkg' not found in any registered repository."
        fi

        IFS=';' read -r r_name r_owner r_repo r_branch app_name <<< "$match_info"

        if [[ "$r_name" == "official" ]]; then
            pkg="recipes/$app_name"
        else
            pkg="recipes/$r_name/$app_name"
        fi
    fi

    if [[ $EUID -eq 0 ]] && [[ "$is_core" == "false" ]]; then
        log "\e[33mWarning: You are installing an APP as ROOT. This is not recommended.\e[0m"
        read -p "Continue anyway? (y/N): " cont_root
        [[ "$cont_root" != "y" ]] && exit 0
    fi

    read -p "Are you sure you want to install/update $pkg? (y/N): " confirm
    [[ "$confirm" != "y" ]] && exit 0

    fetch_remote_recipe "$pkg" "$r_name" "$r_owner" "$r_repo" "$r_branch" "$app_name" "$is_core"
    local target_dir="$WORK_DIR/$PLATFORM/$pkg"

    # Handle storage directory creation
    local base_storage=$(grep "^BASE_STORAGE_PATH=" "$ENV_FILE" | cut -d'=' -f2)
    if [[ "$is_core" == "false" ]] && [[ -n "$base_storage" ]]; then
        local app_storage="$base_storage/$app_name"
        if [[ ! -d "$app_storage" ]]; then
            log "Creating storage directory: $app_storage"
            mkdir -p "$app_storage"
        fi
    fi

    # For non-core recipes, handle custom subdomain
    if [[ "$is_core" == "false" ]]; then
        get_app_subdomain "$app_name" > /dev/null
    fi

    check_required_config "$target_dir"

    # Run recipe-specific pre-install hook if it exists
    if [[ -f "$target_dir/pre-install.sh" ]]; then
        log "Running pre-install script for $app_name..."
        chmod +x "$target_dir/pre-install.sh"
        (cd "$target_dir" && bash "./pre-install.sh" "$ENV_FILE") || error "Pre-install script failed."
    fi

    # Ensure Podman socket is active
    if [[ $EUID -eq 0 ]]; then
        systemctl enable --now podman.socket &>/dev/null
    else
        systemctl --user enable --now podman.socket &>/dev/null
    fi

    log "Deploying $pkg..."
    run_podman_compose "$target_dir" up -d

    # Run recipe-specific post-install hook if it exists
    if [[ -f "$target_dir/post-install.sh" ]]; then
        log "Running post-install script for $app_name..."
        chmod +x "$target_dir/post-install.sh"
        (cd "$target_dir" && bash "./post-install.sh" "$ENV_FILE") || error "Post-install script failed."
    fi

    if [[ "$pkg" == "core/traefik" ]] && [[ $EUID -eq 0 ]]; then
        do_create_systemd_service "$target_dir"
    fi
}

function do_create_systemd_service() {
    local target_dir=$1
    ln -sf "$ENV_FILE" "$target_dir/.env" 2>/dev/null || true
    
    local compose_bin
    compose_bin=$(resolve_compose_bin)
    
    log "Creating systemd service for Traefik..."
    cat <<EOF | sudo tee /etc/systemd/system/tycho-traefik.service > /dev/null
[Unit]
Description=Tycho Traefik Service
After=network.target

[Service]
Type=simple
WorkingDirectory=$target_dir
ExecStart=$compose_bin up
ExecStop=$compose_bin down
Restart=always

[Install]
WantedBy=multi-user.target
EOF
    sudo systemctl daemon-reload
    sudo systemctl enable tycho-traefik.service
    log "Systemd service 'tycho-traefik' enabled."
}

function do_uninstall() {
    check_env
    local pkg=$1
    [[ -z "$pkg" ]] && error "Usage: tycho uninstall <package>"

    local target_dir=$(resolve_local_pkg_dir "$pkg")
    if [[ ! -d "$target_dir" ]]; then
        error "Package $pkg is not installed locally."
    fi

    read -p "Are you sure you want to UNINSTALL $pkg? This will stop services. (y/N): " confirm
    [[ "$confirm" != "y" ]] && exit 0

    log "Uninstalling $pkg..."
    local down_args=""
    read -p "Remove persistent volumes? (y/N): " rm_volumes
    [[ "$rm_volumes" == "y" ]] && down_args="$down_args --volumes"
    
    run_podman_compose "$target_dir" down $down_args
    
    if [[ "$pkg" == "traefik" ]] || [[ "$pkg" == "core/traefik" ]] && [[ $EUID -eq 0 ]]; then
        sudo systemctl disable --now tycho-traefik.service 2>/dev/null
        sudo rm -f /etc/systemd/system/tycho-traefik.service
        sudo systemctl daemon-reload
    fi

    read -p "Delete local recipe files? (y/N): " cleanup
    [[ "$cleanup" == "y" ]] && rm -rf "$target_dir"
    
    log "$pkg has been uninstalled."
}

function fetch_and_list_recipes() {
    local r_name=$1
    local r_owner=$2
    local r_repo=$3
    local r_branch=$4

    local api_url="https://api.github.com/repos/$r_owner/$r_repo"
    local raw_url="https://raw.githubusercontent.com/$r_owner/$r_repo/$r_branch"

    local recipes_json
    recipes_json=$(curl -s -f "$api_url/contents/.tycho/recipes/$PLATFORM?ref=$r_branch")
    if [[ $? -ne 0 ]]; then
        log "\e[33mWarning: Failed to reach GitHub API for repository '$r_name' ($r_owner/$r_repo).\e[0m"
        return
    fi

    echo "$recipes_json" | jq -r '.[] | select(.type == "dir") | .name' | while read -r name; do
        local description
        description=$(curl -s -f "$raw_url/.tycho/recipes/$PLATFORM/$name/package.json" | jq -r '.description // empty' 2>/dev/null)
        printf "%-25s %-15s %s\n" "$name" "$r_name" "${description:-(No description)}"
    done
}

function do_list() {
    echo ""
    printf "\e[1m%-25s %-15s %s\e[0m\n" "RECIPE" "REPOSITORY" "DESCRIPTION"
    echo "--------------------------------------------------------------------------------"

    # 1. Official Repository
    fetch_and_list_recipes "official" "$REPO_USER" "$REPO_NAME" "$REPO_BRANCH"

    # 2. Third-party Repositories
    if [[ -f "$WORK_DIR/repositories.json" ]]; then
        local repos=$(jq -c '.[]' "$WORK_DIR/repositories.json" 2>/dev/null)
        if [[ -n "$repos" ]]; then
            while read -r repo_json; do
                local r_name=$(echo "$repo_json" | jq -r '.name')
                local r_owner=$(echo "$repo_json" | jq -r '.owner')
                local r_repo=$(echo "$repo_json" | jq -r '.repo')
                local r_branch=$(echo "$repo_json" | jq -r '.branch')
                fetch_and_list_recipes "$r_name" "$r_owner" "$r_repo" "$r_branch"
            done <<< "$repos"
        fi
    fi
    echo ""
}

function resolve_latest_matching_tag() {
    local owner=$1
    local repo=$2
    local tag=$3

    if [[ "$tag" =~ ^v?[0-9]+$ ]] || [[ "$tag" =~ ^v?[0-9]+\.[0-9]+$ ]] || [[ "$tag" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        local tags_json
        tags_json=$(curl -s -f "https://api.github.com/repos/$owner/$repo/tags")
        if [[ $? -eq 0 ]] && [[ -n "$tags_json" ]] && [[ "$tags_json" != "[]" ]]; then
            local tag_names
            tag_names=$(echo "$tags_json" | jq -r '.[].name' 2>/dev/null)
            if [[ -n "$tag_names" ]]; then
                local search_prefix="${tag#v}"
                local matched_tags=""
                while read -r name; do
                    local clean_name="${name#v}"
                    if [[ "$clean_name" == "$search_prefix" ]] || [[ "$clean_name" == "$search_prefix."* ]]; then
                        matched_tags="$matched_tags$name"$'\n'
                    fi
                done <<< "$tag_names"
                
                if [[ -n "$matched_tags" ]]; then
                    local resolved_tag=$(echo "$matched_tags" | grep -v '^$' | sort -V | tail -n 1)
                    if [[ -n "$resolved_tag" ]]; then
                        echo "$resolved_tag"
                        return 0
                    fi
                fi
            fi
        fi
    fi

    echo "$tag"
    return 0
}

function select_repository_tag() {
    local owner=$1
    local repo=$2
    local fallback_branch="main"

    local tags_json
    tags_json=$(curl -s -f "https://api.github.com/repos/$owner/$repo/tags")
    if [[ $? -ne 0 ]] || [[ -z "$tags_json" ]] || [[ "$tags_json" == "[]" ]]; then
        echo "$fallback_branch;false"
        return 0
    fi

    local jq_filter='
      map(select(.name | test("^v?[0-9]+(\\.[0-9]+)*")))
      | map(
          .name as $name
          | ($name | sub("^v"; "")) as $clean
          | ($clean | split(".")) as $parts
          | {
              name: $name,
              clean: $clean,
              major: ($parts[0] // "0"),
              minor: ($parts[1] // "0"),
              patch: ($parts[2] // "0"),
              has_v: ($name | startswith("v"))
            }
        )
      | map(. + {
          major_num: (.major | tonumber? // 0),
          minor_num: (.minor | tonumber? // 0),
          patch_num: (.patch | tonumber? // 0)
        })
      | sort_by(.major_num, .minor_num, .patch_num)
      | reverse
      | . as $all
      | ($all | limit(3; .)) as $recent
      | ($all | group_by(.major_num) | map(reverse | .[0]) | reverse) as $majors
      | ($all | group_by([.major_num, .minor_num]) | map(reverse | .[0]) | reverse) as $minors
      | [
          ($recent[] | {
            label: ("Pin to specific release tag: " + .name),
            value: .name
          }),
          ($majors[] | {
            label: ("Track major version: " + (if .has_v then "v" else "" end) + .major + " (resolves to: " + .name + ")"),
            value: ((if .has_v then "v" else "" end) + .major)
          }),
          ($minors[] | {
            label: ("Track minor version: " + (if .has_v then "v" else "" end) + .major + "." + .minor + " (resolves to: " + .name + ")"),
            value: ((if .has_v then "v" else "" end) + .major + "." + .minor)
          })
        ]
      | unique_by(.value)
      | .[] | "\(.label);\(.value)"
    '

    local resolved_options=$(echo "$tags_json" | jq -r "$jq_filter" 2>/dev/null)
    if [[ -z "$resolved_options" ]]; then
        echo "$fallback_branch;false"
        return 0
    fi

    echo -e "\n\e[1mSelect a version tag/branch for '$owner/$repo':\e[0m" >&2
    
    local -a menu_labels
    local -a menu_values
    local idx=1

    while read -r line; do
        if [[ -n "$line" ]]; then
            local label="${line%%;*}"
            local value="${line#*;}"
            menu_labels+=("$label")
            menu_values+=("$value")
            echo -e "  ${idx}) $label" >&2
            idx=$((idx+1))
        fi
    done <<< "$resolved_options"

    menu_labels+=("Default to main (development/unstable branch)")
    menu_values+=("main")
    echo -e "  ${idx}) Default to main (development/unstable branch)" >&2

    local max_choice=${#menu_labels[@]}
    while true; do
        read -p "Enter choice [1-${max_choice}, default: 1]: " choice >&2
        choice=${choice:-1}
        
        if [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$max_choice" ]]; then
            local selected_idx=$((choice-1))
            local selected_val="${menu_values[selected_idx]}"
            local final_has_tag="true"
            if [[ "$selected_val" == "main" ]]; then
                final_has_tag="false"
            fi
            echo "${selected_val};${final_has_tag}"
            return 0
        else
            echo "Invalid selection. Please choose a number between 1 and ${max_choice}." >&2
        fi
    done
}

function do_repo() {
    local cmd=$1
    case "$cmd" in
        add)
            local name=$2
            local source=$3
            [[ -z "$name" ]] || [[ -z "$source" ]] && error "Usage: tycho repo add <name> <owner>/<repo>[@branch]"
            
            # Automatically clean up full GitHub URL formats
            if [[ "$source" == *"github.com/"* ]]; then
                source="${source#*github.com/}"
            elif [[ "$source" == *"github.com:"* ]]; then
                source="${source#*github.com:}"
            fi
            source="${source%.git}" # Strip optional .git suffix
            
            if [[ ! "$name" =~ ^[a-zA-Z0-9-]+$ ]]; then
                error "Invalid repository name. Use only letters, numbers, and hyphens."
            fi
            
            if [[ "$name" == "official" ]] || [[ "$name" == "core" ]] || [[ "$name" == "recipes" ]]; then
                error "Repository name '$name' is reserved."
            fi

            local owner=""
            local repo=""
            local branch="main"
            local has_tag=true
            
            if [[ "$source" != *"*"* ]] && [[ "$source" != *"@"* ]]; then
                has_tag=false
            fi
            
            if [[ "$source" == *"*"* ]] || [[ "$source" == *"@"* ]]; then
                local tmp_src="${source%%@*}"
                branch="${source#*@}"
                source="$tmp_src"
            fi
            
            if [[ "$source" != *"/"* ]]; then
                error "Invalid repository source. Must be in the format 'owner/repo' or 'owner/repo@branch'."
            fi
            
            owner="${source%%/*}"
            repo="${source#*/}"
            
            if [[ "$has_tag" == "false" ]]; then
                log "Fetching available release tags for $owner/$repo..."
                local select_res=$(select_repository_tag "$owner" "$repo")
                IFS=';' read -r branch has_tag <<< "$select_res"
            fi
            
            if [[ "$has_tag" == "true" ]]; then
                log "Resolving tag/branch '$branch' for $owner/$repo..."
                local resolved=$(resolve_latest_matching_tag "$owner" "$repo" "$branch")
                if [[ "$resolved" != "$branch" ]]; then
                    log "Resolved short tag '$branch' to latest matching release '$resolved'."
                    branch="$resolved"
                fi
            fi
            
            # Fetch repository metadata description from .tycho/repository.json
            local r_desc=""
            local meta_json
            meta_json=$(curl -s -f "https://raw.githubusercontent.com/$owner/$repo/$branch/.tycho/repository.json")
            if [[ $? -eq 0 ]] && [[ -n "$meta_json" ]]; then
                r_desc=$(echo "$meta_json" | jq -r '.description // empty' 2>/dev/null)
                local meta_name
                meta_name=$(echo "$meta_json" | jq -r '.name' 2>/dev/null)
                log "Found repository metadata: '$meta_name' - $r_desc"
            fi

            if [[ ! -f "$WORK_DIR/repositories.json" ]]; then
                echo "[]" > "$WORK_DIR/repositories.json"
            fi
            
            local exists=$(jq -r ".[] | select(.name == \"$name\") | .name" "$WORK_DIR/repositories.json" 2>/dev/null)
            if [[ -n "$exists" ]]; then
                read -p "Repository '$name' already exists. Overwrite? (y/N): " overwrite
                [[ "$overwrite" != "y" ]] && exit 0
                local tmp_file=$(mktemp)
                jq "del(.[] | select(.name == \"$name\"))" "$WORK_DIR/repositories.json" > "$tmp_file"
                mv "$tmp_file" "$WORK_DIR/repositories.json"
            fi
            
            local tmp_file=$(mktemp)
            jq ". += [{\"name\": \"$name\", \"owner\": \"$owner\", \"repo\": \"$repo\", \"branch\": \"$branch\", \"description\": \"$r_desc\"}]" "$WORK_DIR/repositories.json" > "$tmp_file"
            mv "$tmp_file" "$WORK_DIR/repositories.json"
            
            if [[ "$has_tag" == "false" ]]; then
                log "\e[33mWarning: No branch/tag specified. Defaulting to 'main'. This is not recommended for production security.\e[0m"
            fi
            log "Added repository '$name' ($owner/$repo@$branch)."
            ;;
            
        list)
            echo ""
            printf "\e[1m%-15s %-30s %-10s %s\e[0m\n" "NAME" "URL/SOURCE" "BRANCH" "DESCRIPTION"
            echo "----------------------------------------------------------------------------------------------------"
            printf "%-15s %-30s %-10s %s\n" "official" "$REPO_USER/$REPO_NAME" "$REPO_BRANCH" "Official Tycho core services and application recipes repository"
            
            if [[ -f "$WORK_DIR/repositories.json" ]]; then
                jq -c '.[]' "$WORK_DIR/repositories.json" 2>/dev/null | while read -r repo_json; do
                    if [[ -n "$repo_json" ]]; then
                        local r_name=$(echo "$repo_json" | jq -r '.name')
                        local r_owner=$(echo "$repo_json" | jq -r '.owner')
                        local r_repo=$(echo "$repo_json" | jq -r '.repo')
                        local r_branch=$(echo "$repo_json" | jq -r '.branch')
                        local r_desc=$(echo "$repo_json" | jq -r '.description // empty')
                        printf "%-15s %-30s %-10s %s\n" "$r_name" "$r_owner/$r_repo" "$r_branch" "${r_desc:-(No description)}"
                    fi
                done
            fi
            echo ""
            ;;
            
        remove)
            local name=$2
            [[ -z "$name" ]] && error "Usage: tycho repo remove <name>"
            
            if [[ ! -f "$WORK_DIR/repositories.json" ]]; then
                error "No repositories configured."
            fi
            
            local exists=$(jq -r ".[] | select(.name == \"$name\") | .name" "$WORK_DIR/repositories.json" 2>/dev/null)
            if [[ -z "$exists" ]]; then
                error "Repository '$name' not found."
            fi
            
            local tmp_file=$(mktemp)
            jq "del(.[] | select(.name == \"$name\"))" "$WORK_DIR/repositories.json" > "$tmp_file"
            mv "$tmp_file" "$WORK_DIR/repositories.json"
            
            log "Removed repository '$name'."
            ;;
            
        update)
            log "Updating recipe repositories..."
            log "Checking repository 'official' ($REPO_USER/$REPO_NAME@$REPO_BRANCH)..."
            if curl -s -f -I "https://api.github.com/repos/$REPO_USER/$REPO_NAME" &>/dev/null; then
                log "  \e[32m[OK]\e[0m official repository is online"
            else
                log "  \e[31m[FAILED]\e[0m official repository is offline or invalid"
            fi
            
            if [[ -f "$WORK_DIR/repositories.json" ]]; then
                local repos=$(jq -c '.[]' "$WORK_DIR/repositories.json" 2>/dev/null)
                if [[ -n "$repos" ]]; then
                    while read -r repo_json; do
                        local r_name=$(echo "$repo_json" | jq -r '.name')
                        local r_owner=$(echo "$repo_json" | jq -r '.owner')
                        local r_repo=$(echo "$repo_json" | jq -r '.repo')
                        local r_branch=$(echo "$repo_json" | jq -r '.branch')
                        
                        log "Checking repository '$r_name' ($r_owner/$r_repo@$r_branch)..."
                        if curl -s -f -I "https://api.github.com/repos/$r_owner/$r_repo" &>/dev/null; then
                            log "  \e[32m[OK]\e[0m $r_name is online"
                        else
                            log "  \e[31m[FAILED]\e[0m $r_name is offline or invalid"
                        fi
                    done <<< "$repos"
                fi
            fi
            log "Update check complete!"
            ;;

        boilerplate)
            local target_folder=$2
            [[ -z "$target_folder" ]] && target_folder="."
            
            log "Preparing Tycho repository boilerplate inside '$target_folder'..."
            mkdir -p "$target_folder/.tycho/core/podman" "$target_folder/.tycho/recipes/podman"
            
            local repo_name=$(basename "$(cd "$target_folder" && pwd)")
            read -p "Enter repository name [default: $repo_name]: " r_name
            r_name=${r_name:-$repo_name}
            
            read -p "Enter repository description [default: Custom Tycho recipe repository]: " r_desc
            r_desc=${r_desc:-"Custom Tycho recipe repository"}
            
            read -p "Enter author/vendor [default: $(whoami)]: " r_author
            r_author=${r_author:-$(whoami)}
            
            cat <<EOF > "$target_folder/.tycho/repository.json"
{
  "name": "$r_name",
  "description": "$r_desc",
  "author": "$r_author",
  "version": "1.0.0"
}
EOF
            log "Successfully prepared Tycho boilerplate in $target_folder/.tycho/"
            ;;
            
        *)
            echo "Usage:"
            echo "  tycho repo add <name> <owner>/<repo>[@branch]   Add a recipe repository"
            echo "  tycho repo list                                 List added repositories"
            echo "  tycho repo remove <name>                        Remove a repository"
            echo "  tycho repo update                               Verify all repositories"
            echo "  tycho repo boilerplate <folder>                 Create a new repository template"
            echo ""
            ;;
    esac
}

function do_stats() {
    log "Server Statistics ($(whoami)):"
    echo "--- Status ---"
    podman ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    echo ""
    echo "--- Resources ---"
    podman stats --no-stream --format "table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}\t{{.NetIO}}"
}

function do_backup() {
    check_env
    
    local backup_file=""
    local service=""
    local with_data=false
    local non_interactive=false
    local remote_dest=""
    local incremental=false
    local port=22
    local identity=""
    local keep=""
    local stop_services=false
    
    # Parse options
    while [[ $# -gt 0 ]]; do
        case $1 in
            --service)
                service="$2"
                shift 2
                ;;
            --with-data|-d)
                with_data=true
                shift
                ;;
            --non-interactive|-y)
                non_interactive=true
                shift
                ;;
            --remote)
                remote_dest="$2"
                shift 2
                ;;
            --incremental)
                incremental=true
                shift
                ;;
            --port)
                port="$2"
                shift 2
                ;;
            --identity)
                identity="$2"
                shift 2
                ;;
            --keep)
                keep="$2"
                shift 2
                ;;
            --stop-services)
                stop_services=true
                shift
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                if [[ -z "$backup_file" ]]; then
                    backup_file="$1"
                else
                    error "Multiple backup files or arguments specified: $1"
                fi
                shift
                ;;
        esac
    done

    # Resolve active storage path
    local base_storage=$(grep "^BASE_STORAGE_PATH=" "$ENV_FILE" | cut -d'=' -f2)
    if [[ -z "$base_storage" ]]; then
        error "BASE_STORAGE_PATH not configured in .env."
    fi

    # Determine default backup name if empty and not in folder-based incremental mode
    if [[ -z "$backup_file" ]] && [[ "$incremental" == "false" ]]; then
        local timestamp=$(date +%Y%m%d-%H%M%S)
        if [[ -n "$service" ]]; then
            backup_file="tycho-backup-$service-$timestamp.tar.gz"
        else
            backup_file="tycho-backup-$timestamp.tar.gz"
        fi
    fi

    log "Starting backup..."
    if [[ -n "$service" ]]; then
        log "  Scope: Service-level ($service)"
    else
        log "  Scope: Full system"
    fi
    log "  Type: $([[ "$with_data" == "true" ]] && echo 'Metadata + Data' || echo 'Metadata only')"
    log "  Mode: $([[ "$incremental" == "true" ]] && echo 'Incremental syncing' || echo 'Standard archive')"

    # Validate target directories/services
    local source_workdir="$WORK_DIR"
    local source_data=""
    
    if [[ -n "$service" ]]; then
        local target_dir=$(resolve_local_pkg_dir "$service")
        if [[ ! -d "$target_dir" ]]; then
            error "Service $service is not installed locally."
        fi
        source_workdir="$target_dir"
        if [[ "$with_data" == "true" ]]; then
            source_data="$base_storage/$(basename "$target_dir")"
            if [[ ! -d "$source_data" ]]; then
                log "\e[33mWarning: Data folder '$source_data' does not exist.\e[0m"
            fi
        fi
    else
        if [[ "$with_data" == "true" ]]; then
            source_data="$base_storage"
        fi
    fi

    # Interactive stop checks (or non-interactive force stop if requested)
    local active_services=()
    local should_stop=false
    
    if [[ "$non_interactive" == "false" ]]; then
        read -p "Stop running services to ensure backup consistency? (y/N): " confirm_stop
        [[ "$confirm_stop" == "y" ]] && should_stop=true
    elif [[ "$stop_services" == "true" ]]; then
        should_stop=true
    fi

    if [[ "$should_stop" == "true" ]]; then
        log "Stopping active containers..."
        local scan_dir="$WORK_DIR/$PLATFORM"
        if [[ -n "$service" ]]; then
            scan_dir=$(resolve_local_pkg_dir "$service")
        fi
        
        while read -r compose_dir; do
            if [[ -d "$compose_dir" ]] && [[ -f "$compose_dir/compose.yaml" ]]; then
                if run_podman_compose "$compose_dir" ps -q &>/dev/null; then
                    log "  Stopping $(basename "$compose_dir")...."
                    run_podman_compose "$compose_dir" stop
                    active_services+=("$compose_dir")
                fi
            fi
        done < <(find "$scan_dir" -type d -mindepth 1 -maxdepth 3 2>/dev/null)
    fi

    # Manifest creation
    local meta_tmp=$(mktemp)
    local type_val="full"
    [[ -n "$service" ]] && type_val="service"
    
    echo "TYPE=\"$type_val\"" > "$meta_tmp"
    echo "SERVICE=\"$service\"" >> "$meta_tmp"
    echo "WITH_DATA=\"$with_data\"" >> "$meta_tmp"
    echo "TIMESTAMP=\"$(date +%Y%m%d-%H%M%S)\"" >> "$meta_tmp"

    # Create directory for backup if saving locally
    if [[ -n "$backup_file" ]]; then
        mkdir -p "$(dirname "$backup_file")"
    fi

    local backup_success=false

    if [[ "$incremental" == "true" ]]; then
        # Folder-based incremental backup using rsync
        if [[ -z "$backup_file" ]] && [[ -z "$remote_dest" ]]; then
            error "Incremental local backup requires a target folder argument."
        fi
        
        local sync_target=""
        if [[ -n "$remote_dest" ]]; then
            sync_target="$remote_dest"
            log "Starting remote incremental rsync synchronization to '$sync_target'..."
        else
            sync_target="$backup_file"
            mkdir -p "$sync_target"
            log "Starting local incremental rsync synchronization to '$sync_target'..."
        fi

        # Sync metadata
        local rsync_opts="-avz"
        if [[ -n "$identity" ]]; then
            rsync_opts="$rsync_opts -e 'ssh -p $port -i $identity'"
        else
            rsync_opts="$rsync_opts -e 'ssh -p $port'"
        fi
        
        # Write metadata file directly to source folder to ensure it syncs
        cp "$meta_tmp" "$source_workdir/.tycho-backup-meta"
        
        # Rsync the workdir / service folder
        if [[ -n "$remote_dest" ]]; then
            eval rsync $rsync_opts --delete "$source_workdir/" "$sync_target/metadata/"
            if [[ $? -eq 0 ]]; then
                backup_success=true
            fi
            if [[ -n "$source_data" ]] && [[ -d "$source_data" ]]; then
                log "Syncing application data files..."
                eval rsync $rsync_opts --delete "$source_data/" "$sync_target/data/"
                if [[ $? -ne 0 ]]; then
                    backup_success=false
                fi
            fi
        else
            rsync -av --delete "$source_workdir/" "$sync_target/metadata/"
            if [[ $? -eq 0 ]]; then
                backup_success=true
            fi
            if [[ -n "$source_data" ]] && [[ -d "$source_data" ]]; then
                log "Syncing application data files..."
                rsync -av --delete "$source_data/" "$sync_target/data/"
                if [[ $? -ne 0 ]]; then
                    backup_success=false
                fi
            fi
        fi
        
        # Cleanup local manifest copy in source workdir
        rm -f "$source_workdir/.tycho-backup-meta"
    else
        # Standard archive-based backup
        local tar_tmp_dir=$(mktemp -d)
        
        # Copy files to temp structure to absolute target compatibility and add manifest
        mkdir -p "$tar_tmp_dir/meta"
        cp -R "$source_workdir/" "$tar_tmp_dir/meta/"
        cp "$meta_tmp" "$tar_tmp_dir/meta/.tycho-backup-meta"
        
        local tar_args=("-czf" "$backup_file" "-C" "$tar_tmp_dir" "meta")
        
        if [[ -n "$source_data" ]] && [[ -d "$source_data" ]]; then
            mkdir -p "$tar_tmp_dir/data"
            cp -R "$source_data/" "$tar_tmp_dir/data/"
            tar_args+=("data")
        fi

        log "Creating backup archive at '$backup_file'..."
        tar "${tar_args[@]}" 2>/dev/null
        if [[ $? -eq 0 ]]; then
            backup_success=true
            log "Backup successfully created: $(du -sh "$backup_file" | cut -f1) ($backup_file)"
        else
            log "\e[31mError: Backup compilation failed.\e[0m"
        fi
        
        # Clean up temp folder
        rm -rf "$tar_tmp_dir"
        
        # Push to remote via scp if requested
        if [[ "$backup_success" == "true" ]] && [[ -n "$remote_dest" ]]; then
            log "Transferring archive to remote target '$remote_dest'..."
            local scp_cmd="scp -P $port"
            [[ -n "$identity" ]] && scp_cmd="$scp_cmd -i $identity"
            eval $scp_cmd "$backup_file" "$remote_dest"
            if [[ $? -eq 0 ]]; then
                log "Remote transfer complete!"
            else
                log "\e[31mError: Remote transfer failed.\e[0m"
                backup_success=false
            fi
        fi
    fi

    # Clean up temp manifest
    rm -f "$meta_tmp"

    # Start services again if stopped
    if [[ "${#active_services[@]}" -gt 0 ]]; then
        log "Restarting stopped containers..."
        for compose_dir in "${active_services[@]}"; do
            log "  Starting $(basename "$compose_dir")...."
            run_podman_compose "$compose_dir" start
        done
    fi

    # Apply Retention policy if requested
    if [[ "$backup_success" == "true" ]] && [[ -n "$keep" ]]; then
        # Validate keep is integer
        if [[ ! "$keep" =~ ^[0-9]+$ ]]; then
            error "Retention keep count '--keep' must be a positive integer."
        fi

        if [[ -n "$remote_dest" ]] && [[ "$incremental" == "false" ]]; then
            # Prune remote archives
            log "Applying remote retention policy (keeping newest $keep)..."
            local remote_host_path=$(echo "$remote_dest" | cut -d':' -f1)
            local remote_dir=$(echo "$remote_dest" | cut -d':' -f2)
            local ssh_cmd="ssh -p $port"
            [[ -n "$identity" ]] && ssh_cmd="$ssh_cmd -i $identity"
            
            local match_pattern="tycho-backup-*.tar.gz"
            [[ -n "$service" ]] && match_pattern="tycho-backup-$service-*.tar.gz"
            
            # Formulate remote prune command
            eval $ssh_cmd "$remote_host_path" "\"ls -tp $remote_dir/$match_pattern 2>/dev/null | grep -v '/' | tail -n +$((keep + 1)) | xargs -I {} rm -f $remote_dir/{}\""
        elif [[ "$incremental" == "false" ]]; then
            # Prune local archives
            log "Applying local retention policy (keeping newest $keep)..."
            local target_dir_path=$(dirname "$backup_file")
            local match_pattern="tycho-backup-*.tar.gz"
            [[ -n "$service" ]] && match_pattern="tycho-backup-$service-*.tar.gz"
            
            # Find and sort local matching archives
            local old_backups=()
            while read -r file; do
                if [[ -f "$file" ]]; then
                    old_backups+=("$file")
                fi
            done < <(ls -t "$target_dir_path"/$match_pattern 2>/dev/null | tail -n +$((keep + 1)))

            for old_f in "${old_backups[@]}"; do
                log "  Pruning old backup: $(basename "$old_f")"
                rm -f "$old_f"
            done
        fi
    fi

    if [[ "$backup_success" == "true" ]]; then
        log "Backup process completed successfully!"
    else
        error "Backup process failed."
    fi
}

function do_restore() {
    local backup_file=""
    local non_interactive=false
    
    # Parse options
    while [[ $# -gt 0 ]]; do
        case $1 in
            --non-interactive|-y)
                non_interactive=true
                shift
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                if [[ -z "$backup_file" ]]; then
                    backup_file="$1"
                else
                    error "Multiple arguments specified: $1"
                fi
                shift
                ;;
        esac
    done

    [[ -z "$backup_file" ]] && error "Usage: tycho restore <backup_file_or_dir> [--non-interactive]"
    [[ ! -e "$backup_file" ]] && error "Backup source '$backup_file' not found."

    log "Reading backup manifest..."
    local manifest_content=""
    if [[ -d "$backup_file" ]]; then
        if [[ -f "$backup_file/metadata/.tycho-backup-meta" ]]; then
            manifest_content=$(cat "$backup_file/metadata/.tycho-backup-meta")
        fi
    else
        manifest_content=$(tar -xf "$backup_file" -O meta/.tycho-backup-meta 2>/dev/null)
    fi

    if [[ -z "$manifest_content" ]]; then
        error "Could not read backup manifest (.tycho-backup-meta). Invalid backup format."
    fi

    # Parse variables from manifest safely
    local TYPE=""
    local SERVICE=""
    local WITH_DATA=""
    local TIMESTAMP=""
    
    # Load manifest variables
    eval "$manifest_content"

    log "Backup Manifest Loaded:"
    log "  Timestamp: $TIMESTAMP"
    log "  Scope: $([[ "$TYPE" == "service" ]] && echo "Service-level ($SERVICE)" || echo "Full system")"
    log "  Contains data: $WITH_DATA"

    if [[ "$non_interactive" == "false" ]]; then
        read -p "WARNING: Restoring will overwrite existing configuration/data. Continue? (y/N): " confirm
        [[ "$confirm" != "y" ]] && exit 0
    fi

    # Resolve paths
    check_env
    local base_storage=$(grep "^BASE_STORAGE_PATH=" "$ENV_FILE" | cut -d'=' -f2)
    if [[ -z "$base_storage" ]]; then
        error "BASE_STORAGE_PATH not configured in .env."
    fi

    # Stopping active services
    if [[ "$TYPE" == "service" ]]; then
        local target_dir=$(resolve_local_pkg_dir "$SERVICE")
        if [[ -d "$target_dir" ]] && [[ -f "$target_dir/compose.yaml" ]]; then
            log "Stopping service $SERVICE..."
            run_podman_compose "$target_dir" down 2>/dev/null
        fi
    else
        log "Stopping all active services..."
        while read -r compose_dir; do
            if [[ -d "$compose_dir" ]] && [[ -f "$compose_dir/compose.yaml" ]]; then
                log "  Stopping $(basename "$compose_dir")..."
                run_podman_compose "$compose_dir" down 2>/dev/null
            fi
        done < <(find "$WORK_DIR/$PLATFORM" -type d -mindepth 2 -maxdepth 3 2>/dev/null)
    fi

    log "Restoring files..."
    local restore_success=false

    if [[ -d "$backup_file" ]]; then
        # Incremental directory restore using rsync
        if [[ "$TYPE" == "service" ]]; then
            local target_dir=$(resolve_local_pkg_dir "$SERVICE")
            if [[ -z "$target_dir" ]]; then
                target_dir="$WORK_DIR/$PLATFORM/recipes/$SERVICE"
            fi
            mkdir -p "$target_dir"
            rsync -av --delete "$backup_file/metadata/" "$target_dir/"
            if [[ $? -eq 0 ]]; then
                restore_success=true
            fi
            if [[ "$WITH_DATA" == "true" ]]; then
                local target_data="$base_storage/$SERVICE"
                mkdir -p "$target_data"
                rsync -av --delete "$backup_file/data/" "$target_data/"
                if [[ $? -ne 0 ]]; then
                    restore_success=false
                fi
            fi
        else
            mkdir -p "$WORK_DIR"
            rsync -av --delete "$backup_file/metadata/" "$WORK_DIR/"
            if [[ $? -eq 0 ]]; then
                restore_success=true
            fi
            if [[ "$WITH_DATA" == "true" ]]; then
                mkdir -p "$base_storage"
                rsync -av --delete "$backup_file/data/" "$base_storage/"
                if [[ $? -ne 0 ]]; then
                    restore_success=false
                fi
            fi
        fi
    else
        # Archive-based tar restore
        local tar_tmp_dir=$(mktemp -d)
        tar -xzf "$backup_file" -C "$tar_tmp_dir"
        if [[ $? -eq 0 ]]; then
            if [[ "$TYPE" == "service" ]]; then
                local target_dir=$(resolve_local_pkg_dir "$SERVICE")
                if [[ -z "$target_dir" ]]; then
                    target_dir="$WORK_DIR/$PLATFORM/recipes/$SERVICE"
                fi
                mkdir -p "$target_dir"
                cp -Rf "$tar_tmp_dir/meta/"* "$target_dir/"
                restore_success=true
                if [[ "$WITH_DATA" == "true" ]] && [[ -d "$tar_tmp_dir/data" ]]; then
                    local target_data="$base_storage/$SERVICE"
                    mkdir -p "$target_data"
                    cp -Rf "$tar_tmp_dir/data/"* "$target_data/"
                fi
            else
                mkdir -p "$WORK_DIR"
                cp -Rf "$tar_tmp_dir/meta/"* "$WORK_DIR/"
                restore_success=true
                if [[ "$WITH_DATA" == "true" ]] && [[ -d "$tar_tmp_dir/data" ]]; then
                    mkdir -p "$base_storage"
                    cp -Rf "$tar_tmp_dir/data/"* "$base_storage/"
                fi
            fi
        fi
        rm -rf "$tar_tmp_dir"
    fi

    if [[ "$restore_success" == "false" ]]; then
        error "File restoration failed."
    fi

    # Read config again in case env was restored
    check_env
    base_storage=$(grep "^BASE_STORAGE_PATH=" "$ENV_FILE" | cut -d'=' -f2)

    # Offer service start
    local start_services=false
    if [[ "$non_interactive" == "false" ]]; then
        read -p "Start restored services? (Y/n): " start_confirm
        [[ "$start_confirm" != "n" ]] && start_services=true
    else
        start_services=true
    fi

    if [[ "$start_services" == "true" ]]; then
        log "Starting restored services..."
        local core_dirs=()
        local recipe_dirs=()
        
        local scan_dir="$WORK_DIR/$PLATFORM"
        if [[ "$TYPE" == "service" ]]; then
            scan_dir=$(resolve_local_pkg_dir "$SERVICE")
            if [[ -z "$scan_dir" ]]; then
                scan_dir="$WORK_DIR/$PLATFORM/recipes/$SERVICE"
            fi
        fi
        
        while read -r compose_dir; do
            if [[ -d "$compose_dir" ]] && [[ -f "$compose_dir/compose.yaml" ]]; then
                if [[ "$compose_dir" == *"/core/"* ]]; then
                    core_dirs+=("$compose_dir")
                else
                    recipe_dirs+=("$compose_dir")
                fi
            fi
        done < <(find "$scan_dir" -type d -mindepth 1 -maxdepth 3 2>/dev/null)
        
        for c_dir in "${core_dirs[@]}"; do
            log "  Starting core service $(basename "$c_dir")..."
            run_podman_compose "$c_dir" up -d
        done
        
        for r_dir in "${recipe_dirs[@]}"; do
            log "  Starting recipe service $(basename "$r_dir")..."
            run_podman_compose "$r_dir" up -d
        done
    fi
    
    log "Restoration complete successfully!"
}

function do_alias() {
    local cmd=$1
    case "$cmd" in
        register|update)
            local subdomain=$2
            local public_ip=""

            # 1. Détection via la connexion SSH active
            if [[ -n "$SSH_CONNECTION" ]]; then
                public_ip=$(echo "$SSH_CONNECTION" | awk '{print $3}')
            fi

            # 2. Repli si non-SSH ou IP privée détectée (ex: test local)
            if [[ -z "$public_ip" ]] || [[ "$public_ip" =~ ^192\.168\. ]] || [[ "$public_ip" =~ ^10\. ]] || [[ "$public_ip" =~ ^127\. ]]; then
                public_ip=$(curl -s --max-time 5 https://ifconfig.me)
            fi

            # Validation finale
            [[ -z "$public_ip" ]] && error "Impossible de détecter l'IP publique du serveur."

            # 3. Récupération des informations d'authentification (.env)
            if [[ -z "$subdomain" ]]; then
                subdomain=$(grep "^DOMAIN_ALIAS=" "$ENV_FILE" | cut -d'=' -f2)
                [[ -z "$subdomain" ]] && error "Usage: tycho alias register <subdomain>"
            fi

            local email=$(grep "^SSL_EMAIL=" "$ENV_FILE" | cut -d'=' -f2)
            [[ -z "$email" ]] && error "Veuillez d'abord exécuter 'tycho setup' pour configurer votre adresse e-mail."

            log "Demande d'alias *.${subdomain}.tycho.cc pointant vers l'IP publique : $public_ip..."

            # 4. Appel API vers le service d'enregistrement (naming-api de tycho.cc)
            local response=$(curl -s -w "\n%{http_code}" -X POST \
                -H "Content-Type: application/json" \
                -d "{\"subdomain\": \"$subdomain\", \"email\": \"$email\", \"ip\": \"$public_ip\"}" \
                "https://api.tycho.cc/v1/alias/register")

            local http_code=$(echo "$response" | tail -n1)
            local body=$(echo "$response" | sed '$d')

            if [[ "$http_code" -eq 200 ]]; then
                log "\e[32mSuccès !\e[0m L'alias *.${subdomain}.tycho.cc pointe désormais vers $public_ip."
                
                # Sauvegarde locale de l'alias dans le fichier .env
                sed -i "/^DOMAIN_ALIAS=/d" "$ENV_FILE"
                echo "DOMAIN_ALIAS=$subdomain" >> "$ENV_FILE"
                
                # Mise à jour du DOMAIN_NAME pour que les recettes futures s'installent sous cet alias
                sed -i "s|DOMAIN_NAME=.*|DOMAIN_NAME=${subdomain}.tycho.cc|g" "$ENV_FILE"
                
                log "Configuration locale mise à jour avec DOMAIN_NAME=${subdomain}.tycho.cc"
            else
                local err_msg=$(echo "$body" | jq -r '.error // "Erreur inconnue"')
                error "L'enregistrement a échoué (Code $http_code) : $err_msg"
            fi
            ;;
        *)
            echo "Usage:"
            echo "  tycho alias register <sous-domaine>  Enregistrer un alias *.sous-domaine.tycho.cc"
            echo "  tycho alias update                   Mettre à jour l'IP pour l'alias existant"
            echo ""
            ;;
    esac
}

function do_upgrade() {
    log "Upgrading Tycho CLI..."
    
    # Resolve the latest version tag from GitHub API (including pre-releases)
    local resolved_version=""
    resolved_version=$(curl -s -f "$GITHUB_API/releases" | jq -r '.[0].tag_name' 2>/dev/null)
    if [[ $? -ne 0 ]] || [[ -z "$resolved_version" ]] || [[ "$resolved_version" == "null" ]]; then
        resolved_version="latest"
    fi
    
    # Check if the resolved latest version is a pre-release (starts with v0. or contains a hyphen)
    if [[ "$resolved_version" == v0.* ]] || [[ "$resolved_version" == *-[a-zA-Z]* ]]; then
        local stable_tag=""
        stable_tag=$(curl -s -f "$GITHUB_API/releases/latest" | jq -r '.tag_name' 2>/dev/null || echo "")
        
        if [[ -n "$stable_tag" ]] && [[ "$stable_tag" != "$resolved_version" ]]; then
            local saved_pref=""
            if [[ -f "$WORK_DIR/release_preference" ]]; then
                saved_pref=$(cat "$WORK_DIR/release_preference" | xargs)
            fi
            
            local choice="2"
            if [[ "$saved_pref" == "unstable" ]]; then
                choice="1"
                log "Using saved preference: Proceed with pre-release ($resolved_version)"
                echo -e "To reset or change this option, simply delete or edit the file: \e[1m$WORK_DIR/release_preference\e[0m\n" >&2
            elif [[ "$saved_pref" == "stable" ]]; then
                choice="2"
                log "Using saved preference: Fall back to stable version ($stable_tag)"
                echo -e "To reset or change this option, simply delete or edit the file: \e[1m$WORK_DIR/release_preference\e[0m\n" >&2
            else
                echo -e "\e[33m\e[1mNOTICE: The latest version is a pre-release: $resolved_version\e[0m" >&2
                echo -e "The latest stable production release is: $stable_tag" >&2
                echo "" >&2
                echo "Would you like to upgrade to the pre-release or fall back to the stable version?" >&2
                echo "  1) Proceed with pre-release ($resolved_version)" >&2
                echo "  2) Fall back to latest stable version ($stable_tag) [default]" >&2
                echo "  3) Cancel upgrade" >&2
                
                read -p "Choice [1-3, default: 2]: " choice
                choice=${choice:-2}
                
                if [[ "$choice" == "1" ]] || [[ "$choice" == "2" ]]; then
                    local remember=""
                    read -p "Remember this choice for future upgrades? (y/N): " remember
                    remember=${remember:-n}
                    if [[ "$remember" == "y" || "$remember" == "Y" ]]; then
                        mkdir -p "$WORK_DIR"
                        if [[ "$choice" == "1" ]]; then
                            if [[ $EUID -eq 0 ]]; then
                                echo "unstable" | sudo tee "$WORK_DIR/release_preference" >/dev/null
                            else
                                echo "unstable" > "$WORK_DIR/release_preference"
                            fi
                            log "Preference saved: 'unstable'."
                        else
                            if [[ $EUID -eq 0 ]]; then
                                echo "stable" | sudo tee "$WORK_DIR/release_preference" >/dev/null
                            else
                                echo "stable" > "$WORK_DIR/release_preference"
                            fi
                            log "Preference saved: 'stable'."
                        fi
                        echo -e "To reset or change this choice, simply delete or edit the file: \e[1m$WORK_DIR/release_preference\e[0m\n" >&2
                    fi
                fi
            fi
            
            case "$choice" in
                1)
                    # Proceed with pre-release
                    ;;
                3)
                    log "Upgrade cancelled."
                    exit 0
                    ;;
                *)
                    resolved_version="$stable_tag"
                    ;;
            esac
        fi
    fi
    
    # Resolve the appropriate download URL
    local download_url=""
    if [[ "$resolved_version" =~ ^v[0-9] ]]; then
        download_url="https://github.com/$REPO_USER/$REPO_NAME/releases/download/$resolved_version/tycho"
    else
        download_url="$GITHUB_RAW/tycho"
    fi

    local tmp_file=$(mktemp)
    if curl -s -f "$download_url" -o "$tmp_file"; then
        # Inject the resolved version directly into the script source to bypass file issues
        sed "s/TYCHO_VERSION=\".*\" # INJECTED_VERSION/TYCHO_VERSION=\"$resolved_version\" # INJECTED_VERSION/g" "$tmp_file" > "$tmp_file.tmp" && mv "$tmp_file.tmp" "$tmp_file"
        chmod 755 "$tmp_file"
        local dest_path=$(readlink -f "$0")
        if sudo mv "$tmp_file" "$dest_path"; then
            
            # Save the new version
            if [[ $EUID -eq 0 ]]; then
                echo "$resolved_version" | sudo tee /etc/tycho/version >/dev/null
            else
                echo "$resolved_version" > "$WORK_DIR/version"
            fi
            
            log "Upgraded successfully to $resolved_version!"
            exit 0
        fi
    fi
    error "Upgrade failed."
}


function usage() {
    echo "Commands:"
    echo "  setup            Initial configuration"
    echo "  list             List available recipes"
    echo "  install <pkg>    Install a recipe or core service"
    echo "  uninstall <pkg>  Remove a service"
    echo "  repo <cmd>       Manage recipe repositories (add, list, remove, update)"
    echo "  backup [file]    Backup configurations (metadata) and application databases"
    echo "                   Options:"
    echo "                     --service <name>      Backup only a specific service"
    echo "                     --with-data, -d       Include persistent application files/data"
    echo "                     --keep <N>            Retain only the newest N timestamped archives"
    echo "                     --remote <dest>       Transfer archive to remote target (scp/rsync)"
    echo "                     --incremental         Use rsync for local/remote folder replication"
    echo "                     --port <port>         Specify remote SSH port (default: 22)"
    echo "                     --identity <key>      Specify SSH private key identity path"
    echo "                     --stop-services       Stop containers in non-interactive mode"
    echo "                     --non-interactive, -y Run silently without interactive prompts"
    echo "  restore <file>   Restore configurations and databases from a backup archive"
    echo "                   Options:"
    echo "                     --non-interactive, -y Run silently without interactive prompts"
    echo "  upgrade          Update this CLI"
    echo "  stats            Monitor containers"
    echo "  ps               List active services"
    echo "  alias <cmd>      Manage wildcard alias subdomains (register, update)"
    echo "                   Options:"
    echo "                     register <subdomain>  Register a new *.subdomain.tycho.cc"
    echo "                     update                Update the server IP for the active subdomain"
    echo ""
}

# Load active version
TYCHO_VERSION="unknown" # INJECTED_VERSION
if [[ "$TYCHO_VERSION" == "unknown" ]] && [[ -f "$WORK_DIR/version" ]]; then
    TYCHO_VERSION=$(cat "$WORK_DIR/version")
fi

# Print Tycho CLI header on each execution (to stderr to preserve pipe sanity)
echo -e "\e[34mTycho CLI ($TYCHO_VERSION) - $([[ $EUID -eq 0 ]] && echo 'SYSTEM MODE' || echo 'USER MODE')\e[0m" >&2

case $1 in
    setup)       do_setup ;;
    list)        do_list ;;
    upgrade)     do_upgrade ;;
    install|up)  do_install "$2" ;;
    uninstall)   do_uninstall "$2" ;;
    repo)        do_repo "$2" "$3" "$4" ;;
    backup)      shift; do_backup "$@" ;;
    restore)     shift; do_restore "$@" ;;
    stats)       do_stats ;;
    alias)       do_alias "$2" "$3" ;;
    ps)          podman ps --filter "label=com.docker.compose.project" ;;
    down)
        check_env
        local target_dir=$(resolve_local_pkg_dir "$2")
        if [[ ! -d "$target_dir" ]]; then
            error "Package $2 is not installed locally."
        fi
        run_podman_compose "$target_dir" down
        ;;
    logs)
        check_env
        local target_dir=$(resolve_local_pkg_dir "$2")
        if [[ ! -d "$target_dir" ]]; then
            error "Package $2 is not installed locally."
        fi
        run_podman_compose "$target_dir" logs -f
        ;;
    *)           usage ;;
esac
